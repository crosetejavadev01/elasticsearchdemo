{
  "info": {
    "_postman_id": "2a8d6e2a-7a7b-4b6a-9c12-4f9c8c2f7b31",
    "name": "Elasticsearch Search Decomposition MVP (Option A vs Option B)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Two requests to compare impact-table results for Option A (_count loop) vs Option B (single _search + filters aggregation). Set {{baseUrl}} to your Spring Boot URL."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Option A — Decompose Impact Table (_count per stage)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/decompose-impact-table",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "decompose-impact-table"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": {\n    \"bool\": {\n      \"must\": [\n        { \"match\": { \"category\": \"electronics\" } }\n      ],\n      \"filter\": [\n        { \"range\": { \"price\": { \"gte\": 50, \"lte\": 200 } } },\n        { \"term\": { \"inStock\": true } }\n      ],\n      \"should\": [\n        { \"term\": { \"brand\": \"Sony\" } },\n        { \"term\": { \"brand\": \"Samsung\" } }\n      ]\n    }\n  }\n}\n"
        }
      },
      "response": []
    },
    {
      "name": "Option B — Decompose Impact Table (single _search + filters agg)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/decompose-impact-table-aggregations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "decompose-impact-table-aggregations"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": {\n    \"bool\": {\n      \"must\": [\n        { \"match\": { \"category\": \"electronics\" } }\n      ],\n      \"filter\": [\n        { \"range\": { \"price\": { \"gte\": 50, \"lte\": 200 } } },\n        { \"term\": { \"inStock\": true } }\n      ],\n      \"should\": [\n        { \"term\": { \"brand\": \"Sony\" } },\n        { \"term\": { \"brand\": \"Samsung\" } }\n      ]\n    }\n  }\n}\n"
        }
      },
      "response": []
    }
  ]
}

